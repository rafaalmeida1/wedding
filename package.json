{
  "name": "wedding-gifts",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "postinstall": "node ./scripts/link-node-bin.mjs",
    "link-node": "node ./scripts/link-node-bin.mjs",
    "predev": "node ./scripts/link-node-bin.mjs",
    "prebuild": "node ./scripts/link-node-bin.mjs",
    "predb:migrate": "node ./scripts/link-node-bin.mjs",
    "predb:generate": "node ./scripts/link-node-bin.mjs",
    "predb:studio": "node ./scripts/link-node-bin.mjs",
    "pretypecheck": "node ./scripts/link-node-bin.mjs",
    "pretest": "node ./scripts/link-node-bin.mjs",
    "dev": "turbo run dev --concurrency=20",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @repo/db db:generate",
    "db:migrate": "pnpm --filter @repo/db db:migrate",
    "db:studio": "pnpm --filter @repo/db db:studio",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:reset": "docker compose down -v && docker compose up -d"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "prettier": "^3.4.2"
  }
}
