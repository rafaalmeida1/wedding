# ---------- Banco e infra ----------
DATABASE_URL=postgresql://postgres:postgres@your-db-host:5432/wedding
REDIS_URL=redis://:password@your-redis-host:6379
# Workers + filas BullMQ usam apenas este Redis (mesma URL na API).

# ---------- Auth ----------
# Replica JWT_SECRET também no projeto Vercel do Next — necessário para upload de imagem (ler wg_access sem chamar a API).
JWT_SECRET=replace-me-with-32-random-chars-aaaaaaaa
JWT_REFRESH_SECRET=replace-me-with-32-random-chars-bbbbbbbb
# 12 horas — API e servidor que emite JWT devem usar os mesmos valores.
JWT_ACCESS_TTL_SECONDS=43200
JWT_REFRESH_TTL_SECONDS=43200

# ---------- Mercado Pago ----------
MP_ACCESS_TOKEN=PROD-replace-me-with-real-token
NEXT_PUBLIC_MP_PUBLIC_KEY=PROD-replace-me-with-real-public-key
MP_WEBHOOK_SECRET=your-mercadopago-webhook-secret
MP_NOTIFICATION_URL=https://your-domain.com/api/webhooks/mercadopago
MP_STATEMENT_DESCRIPTOR=LISTA PRESENTES

# ---------- SMTP (Amazon SES via SMTP) ----------
SMTP_HOST=email-smtp.sa-east-1.amazonaws.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-ses-smtp-user
SMTP_PASSWORD=your-ses-smtp-password
SMTP_FROM_EMAIL=no-reply@your-domain.com
SMTP_FROM_NAME=wedding-gifts

# ---------- Cloudflare R2 ----------
# Replica estes 4 no painel da Vercel (projeto do Next): o upload de imagem do dashboard grava no bucket
# pela Server Action usando PutObject, sem passar pela sua API (evita 401 de cookie entre hosts).
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=wedding

# ---------- Frontend (site Next / Vercel) ----------
# CORS e links de email; deve ser exatamente a origem onde o usuário abre o site (com https).
APP_URL=https://your-frontend.vercel.app

# ---------- API (servidor Node / Docker) ----------
API_PORT=8887
# URL pública **da API**, não do site Next: precisa montar URLs de imagens via proxy R2 quando
# R2_PUBLIC_URL está vazio. No Vercel, NEXT_PUBLIC_API_URL deve apontar para este mesmo origin.
NEXT_PUBLIC_API_URL=https://api-wedding.bitrafa.com.br
API_PUBLIC_ORIGIN=https://api-wedding.bitrafa.com.br
# Mesmo valor em API **e** no build do Next. Use a raiz do domínio (ex.: bitrafa.com.br)
# para incluir frontend e api-*. Nos cookies com SameSite=None o browser envia esse cookie
# no fetch entre subdomínios.
COOKIE_DOMAIN=bitrafa.com.br
COOKIE_SECURE=true

# ---------- Workers ----------
WORKERS_CONCURRENCY=4
