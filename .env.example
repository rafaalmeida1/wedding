# =====================================================================
# Monorepo: único arquivo de secrets — este `/.env` na raiz.
# `apps/api` e `apps/workers` carregam só daqui (veja seus `src/env.ts`).
# Next/Vercel: use `NEXT_PUBLIC_*` aqui para dev ou em Environment Variables na Vercel.
# =====================================================================

# ---------- Banco e infra (docker-compose local) ----------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wedding
REDIS_URL=redis://localhost:6379
KAFKA_BROKERS=localhost:19092
KAFKA_USERNAME=
KAFKA_PASSWORD=
KAFKA_SSL=false

# ---------- Auth ----------
JWT_SECRET=replace-me-with-32-random-chars-aaaaaaaa
JWT_REFRESH_SECRET=replace-me-with-32-random-chars-bbbbbbbb
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# ---------- Mercado Pago (Checkout Transparente) ----------
# Pegue em https://www.mercadopago.com.br/developers/panel/app
# Use TEST-... em dev/sandbox; APP_USR-... em produção.
MP_ACCESS_TOKEN=TEST-replace-me-access-token
NEXT_PUBLIC_MP_PUBLIC_KEY=TEST-replace-me-public-key
# Secret das Notificações (Webhooks) do dashboard MP. Valida x-signature.
MP_WEBHOOK_SECRET=
# URL pública do webhook. Em dev use ngrok: https://<seu-tunnel>.ngrok-free.app/api/webhooks/mercadopago
# Pode deixar vazio para só testar criação de pagamento (sem notificação automática).
MP_NOTIFICATION_URL=
# Texto que aparece na fatura do cartão (máx 22 chars).
MP_STATEMENT_DESCRIPTOR=LISTA PRESENTES

# ---------- SMTP (Amazon SES via SMTP) ----------
SMTP_HOST=email-smtp.sa-east-1.amazonaws.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=wedding-gifts

# ---------- Cloudflare R2 ----------
# Upload: endpoint S3 = https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com (não exponha esse URL no <img>).
# Credenciais de PUT/GET servidor: em Cloudflare → R2 → Manage R2 API Tokens → criar token com permissão Object Read & Write.
# Você recebe ACCESS_KEY_ID + SECRET_ACCESS_KEY (par longo). Tokens da API Cloudflare tipo cfat_* NÃO funcionam no SDK AWS S3.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Nome do bucket (ex.: wedding)
R2_BUCKET_NAME=wedding

# Imagens na loja — escolha UM dos modos:
# (A) Bucket com leitura pública: pub-*.r2.dev ou custom domain (recomendado em produção com domínio próprio).
#     R2_PUBLIC_URL=https://pub-xxxx.r2.dev
# (B) Bucket 100% privado: deixe R2_PUBLIC_URL vazio e defina onde a API expõe o proxy GET:
API_PUBLIC_ORIGIN=http://localhost:8080

# Opcional só no modo (A). No modo (B) deixe vazio ou comente.
# R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ---------- URLs públicas ----------
APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080
API_PORT=8080
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
WORKERS_CONCURRENCY=2
