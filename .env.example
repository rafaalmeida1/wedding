# ---------- Postgres + Redis (local: docker compose; produção: ex. Contabo) ----------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wedding
REDIS_URL=redis://localhost:6379

# ---------- App / cookies ----------
# URL pública do site (mesmo domínio que o browser usa). Obrigatório em produção.
APP_URL=http://localhost:3000
# Não usar NEXT_PUBLIC_APP_URL para texto no dashboard — o código usa APP_URL (servidor) ou VERCEL_URL.
# Para preview *.vercel.app: deixe vazio ou omita — cookie fica host-only.
COOKIE_DOMAIN=
COOKIE_SECURE=false

# ---------- Auth (JWT httpOnly cookies wg_access / wg_refresh) ----------
JWT_SECRET=replace-me-with-32-random-chars-aaaaaaaa
JWT_REFRESH_SECRET=replace-me-with-32-random-chars-bbbbbbbb
JWT_ACCESS_TTL_SECONDS=43200
JWT_REFRESH_TTL_SECONDS=43200

MP_ACCESS_TOKEN=TEST-replace-me-access-token
NEXT_PUBLIC_MP_PUBLIC_KEY=TEST-replace-me-public-key
MP_WEBHOOK_SECRET=
MP_NOTIFICATION_URL=
MP_STATEMENT_DESCRIPTOR=LISTA PRESENTES

# ---------- E-mail transacional (SMTP, ex. Amazon SES) ----------
SMTP_HOST=email-smtp.sa-east-1.amazonaws.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=wedding-gifts

# ---------- Cloudflare R2 ----------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=wedding
