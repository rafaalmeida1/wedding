
# ---------- Banco e infra (docker-compose local) ----------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wedding
REDIS_URL=redis://localhost:6379
# Filas de background (BullMQ) usam o mesmo Redis que rate-limit/cache — sem broker extra.

# ---------- Auth ----------
JWT_SECRET=replace-me-with-32-random-chars-aaaaaaaa
JWT_REFRESH_SECRET=replace-me-with-32-random-chars-bbbbbbbb
# 12 horas (evita logout inesperado ao recarregar; access + refresh devem estar iguais na API e onde roda login)
JWT_ACCESS_TTL_SECONDS=43200
JWT_REFRESH_TTL_SECONDS=43200

MP_ACCESS_TOKEN=TEST-replace-me-access-token
NEXT_PUBLIC_MP_PUBLIC_KEY=TEST-replace-me-public-key
# Secret das Notificações (Webhooks) do dashboard MP. Valida x-signature.
MP_WEBHOOK_SECRET=
MP_NOTIFICATION_URL=
MP_STATEMENT_DESCRIPTOR=LISTA PRESENTES

# ---------- SMTP (Amazon SES via SMTP) ----------
SMTP_HOST=email-smtp.sa-east-1.amazonaws.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=wedding-gifts

# Mesmos valores que na API. O Next (Vercel) precisa deles no env do projeto para gravar no bucket
# na Server Action sem chamar a API (evita 401 por cookie entre hosts).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=wedding
# Opcional: URL pública de leitura (ex. https://pub-xxxx.r2.dev). Vazio = usar proxy da API via NEXT_PUBLIC_API_URL.
# R2_PUBLIC_URL=


API_PUBLIC_ORIGIN=http://localhost:8080

APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080
API_PORT=8080
# Produção (*.bitrafa.com.br etc.): defina domínio raiz. Preview Vercel (*.vercel.app): deixe vazio ou
# omita COOKIE_DOMAIN na API para não forçar Domain incompatível com o hostname do preview.
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
WORKERS_CONCURRENCY=2
